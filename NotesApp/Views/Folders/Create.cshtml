@model NotesApp.ViewModels.FolderViewModel
@{
    ViewData["Title"] = "Create Folder";
}

<form method="post" asp-action="OnCreate" class="form">
    <h1>Create folder here</h1>
    @{
        if (TempData["msg"] != null)
        {
            <label class="text-danger">@TempData["msg"]</label>
        }
    }
    <div class="input">
        <label for="Name">Name</label>
        <input type="text" asp-for="Name" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>
    <div class="buttons">
        <button type="submit" class="btn btn-success">Create</button>
        <a class="text-white" asp-controller="Home" asp-action="Index">  
           <button type="button" class="btn btn-primary">Back</button>
        </a>
    </div>
</form>
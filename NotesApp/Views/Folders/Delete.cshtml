@model FolderModel
@{
    ViewData["Title"] = "Delete Folder page";
}

<section class="delete-container">
    <h1>Are you sure you want to delete this folder?</h1>
    <section class="delete-content">
        <p> Name: @Model.Name</p>
        <p> Notes count: @Model.Notes.Count</p>
    </section>
    <div class="buttons">
        <a class="text-white" asp-controller="Folders" asp-action="OnDelete" asp-route-id=@Model.Id>        
           <button class="btn btn-danger">Delete</button>
        </a>
        <a class="text-white" asp-controller="Home" asp-action="Index">   
           <button class="btn btn-primary">Cancel</button>
        </a>
    </div>
</section>

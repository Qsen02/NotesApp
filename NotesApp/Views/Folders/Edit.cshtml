@model NotesApp.ViewModels.FolderViewModel
@{
    ViewData["Title"] = "Edit Folder page";
}

<form method="post" asp-action="OnEdit" asp-route-id=@Model.Id class="form">
    <h1>Edit folder here</h1>
    @{
        if (TempData["msg"] != null)
        {
            <label class="text-danger">@TempData["msg"]</label>
        }
    }
    <div class="input">
        <label for="Name">Name</label>
        <input type="text" asp-for="Name" value=@Model.Name/>
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>
    <div class="buttons">
        <button type="submit" class="btn btn-success">Save</button>
        <a class="text-white" asp-controller="Home" asp-action="Index">
            <button type="button" class="btn btn-primary">Cancel</button>
        </a>
    </div>
</form>
